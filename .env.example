# Remote airbyte (Postgres externo)
REMOTE_PG_HOST=your_remote_host
REMOTE_PG_PORT=5432
REMOTE_PG_DB=airbyte_db
REMOTE_PG_USER=airbyte_user
REMOTE_PG_PASSWORD=airbyte_pass
REMOTE_PG_SCHEMA=airbyte
REMOTE_PG_SSLMODE=require

# dbt target schema for now
DBT_TARGET_SCHEMA=public

# Prefect (local server)
PREFECT_API_URL=http://prefect_server:4200/api

# Inference models (required to enable scheduled inference deployments)
# MODEL_6H_PATH=/app/models/model_6h.pkl
# MODEL_12H_PATH=/app/models/model_12h.pkl

# Optional Prefect schedules (cron, UTC by default)
# PREFECT_DBT_INCREMENTAL_CRON=5 * * * *
# PREFECT_DBT_GOLD_CRON=15 * * * *
# PREFECT_GOLD_THEN_INFERENCE_CRON=20 * * * *
# PREFECT_INFERENCE_CRON=25 * * * *
# PREFECT_SCHEDULE_TIMEZONE=UTC
