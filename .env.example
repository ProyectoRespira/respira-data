# Local project(Local Postgres on Docker)
PROJECT_DB_HOST=project_postgres
PROJECT_DB_PORT=5432
PROJECT_DB_NAME=project_db
PROJECT_DB_USER=project_user
PROJECT_DB_PASSWORD=project_pass

# Remote airbyte (Postgres externo)
AIRBYTE_DB_HOST=your_remote_host
AIRBYTE_DB_PORT=5432
AIRBYTE_DB_NAME=airbyte_db
AIRBYTE_DB_USER=airbyte_user
AIRBYTE_DB_PASSWORD=airbyte_pass
AIRBYTE_DB_SCHEMA=airbyte

# dbt target schema for now
DBT_TARGET_SCHEMA=public

# Prefect (local server)
PREFECT_API_URL=http://prefect_server:4200/api
